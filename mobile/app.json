{
  "expo": {
    "name": "ViraFlow",
    "slug": "viraflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#08141f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.viraflow.app",
      "adaptiveIcon": {
        "backgroundColor": "#08141f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-audio",
      "expo-notifications"
    ]
  }
}
